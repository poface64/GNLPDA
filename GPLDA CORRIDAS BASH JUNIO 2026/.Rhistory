acc_kpoly2 <- mean(predict(lda(y ~ ., data = trainK2), testK2)$class == testY)
# 4. KPCA (Polinomial Grado 3) + LDA
k_poly3 <- kpca(~., data = trainX, kernel = "polydot", kpar = list(degree = 3, scale = 1, offset = 1), features = 2)
trainK3 <- as.data.frame(rotated(k_poly3)); trainK3$y <- trainY
testK3  <- as.data.frame(predict(k_poly3, as.matrix(testX)))
acc_kpoly3 <- mean(predict(lda(y ~ ., data = trainK3), testK3)$class == testY)
# 5. KPCA (Gaussiano) + LDA
k_rbf <- kpca(~., data = trainX, kernel = "rbfdot", kpar = list(sigma = 0.1), features = 2)
trainKr <- as.data.frame(rotated(k_rbf)); trainKr$y <- trainY
testKr  <- as.data.frame(predict(k_rbf, as.matrix(testX)))
acc_kgauss <- mean(predict(lda(y ~ ., data = trainKr), testKr)$class == testY)
metricas_ds <- rbind(metricas_ds, data.frame(
Dataset = ds_nombre,
LDA_Puro = acc_lda,
PCA_LDA = acc_pcalda,
KPCA_Poly2 = acc_kpoly2,
KPCA_Poly3 = acc_kpoly3,
KPCA_Gauss = acc_kgauss
))
}
resumen_ds <- metricas_ds %>%
group_by(Dataset) %>%
summarise(across(everything(), list(Mean = mean, SD = sd)))
resumen_global <- rbind(resumen_global, resumen_ds)
}
return(resumen_global)
}
