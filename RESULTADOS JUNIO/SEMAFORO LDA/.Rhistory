#### Aquí armar esto ####
library(ggplot2)
library(MASS)
library(kfda)
# =========================================================================
# 1. TABLA DE METADATOS DE LOS CASOS
# =========================================================================
# Esta tabla permite inyectar dinámicamente los valores correctos en los títulos
tabla_casos <- data.frame(
Caso = 1:6,
Obs = c(150, 150, 15, 15, 15, 15),
Vars = c(3, 10, 3, 10, 15, 17),
Atr_Pol = c(9, 65, 9, 65, 135, 170)
)
# =========================================================================
# 2. FUNCIÓN DE EVALUACIÓN, PROYECCIÓN Y EXPORTACIÓN
# =========================================================================
graficadorCyM <- function(num_caso, dataset_expandido, tabla_meta) {
# Extraer metadatos específicos del caso
meta <- tabla_meta[tabla_meta$Caso == num_caso, ]
# Separar variables predictoras (X) y la clase (y)
X <- dataset_expandido[, -ncol(dataset_expandido)]
y <- dataset_expandido[, ncol(dataset_expandido)]
clases <- as.factor(y)
# Subtítulo homogéneo para los tres gráficos del caso
sub_titulo <- paste0("Obs: ", meta$Obs, " | Vars: ", meta$Vars, " | Terms: ", meta$Atr_Pol)
# -------------------------------------------------------------------------
# METODO 1: LDA MANUAL
# -------------------------------------------------------------------------
# Crear un gráfico vacío si el caso es incomputable (p >= n)
if (num_caso >= 4) {
g1 <- ggplot() +
annotate("text", x = 0.5, y = 0.5,
label = "Incomputable\n(Alta Dimensionalidad: p > n)",
size = 4, color = "red", fontface = "bold") +
theme_void() +
labs(title = paste0("LDA Clásico ", num_caso), subtitle = sub_titulo)
} else {
# Ejecutar el LDA manual para los casos 1, 2 y 3
md1E <- LDAM(X, y)
df_manual <- data.frame(Re(md1E$proyecciones[, 1:2])) # Forzar 2D
colnames(df_manual) <- c("LD1", "LD2")
df_manual$Class <- clases
g1 <- ggplot(df_manual, aes(x = LD1, y = LD2, color = Class)) +
geom_point(pch = 16, size = 3, alpha = 0.8) +
labs(title = paste0("LDA Clásico ", num_caso), subtitle = sub_titulo, x = "LD1", y = "LD2")
}
# -------------------------------------------------------------------------
# METODO 2: LDA DE MASS
# -------------------------------------------------------------------------
mmd1E <- lda(X, clases)
m1 <- predict(mmd1E)
df_mass <- data.frame(m1$x[, 1:2]) # Extraer las 2 dimensiones conocidas
colnames(df_mass) <- c("LD1", "LD2")
df_mass$Class <- clases
g2 <- ggplot(df_mass, aes(x = LD1, y = LD2, color = Class)) +
geom_point(pch = 16, size = 3, alpha = 0.8) +
labs(title = paste0("LDA MASS ", num_caso), subtitle = sub_titulo, x = "LD1", y = "LD2")
# -------------------------------------------------------------------------
# APLICAR ESTILO COHESIVO A LOS GRÁFICOS
# -------------------------------------------------------------------------
estilo_comun <- theme_minimal() +
theme(
plot.title = element_text(face = "bold", size = 14, hjust = 0.5),
plot.subtitle = element_text(size = 11, color = "gray30", hjust = 0.5),
axis.title = element_text(size = 11, face = "bold"),
legend.position = "bottom",
legend.title = element_blank(),
legend.text = element_text(size = 10)
)
g1 <- g1 + estilo_comun
g2 <- g2 + estilo_comun
# -------------------------------------------------------------------------
# CONFIGURACIÓN DE EXPORTACIÓN (Dimensiones óptimas para Diapositiva)
# -------------------------------------------------------------------------
# Ancho: 5 pulgadas, Alto: 4.5 pulgadas. Al usar 300 DPI se garantiza nitidez
# y una relación de aspecto ideal para colocarlos lado a lado en PowerPoint/Keynote.
ancho_pulgadas <- 5
alto_pulgadas <- 4.5
resolucion_dpi <- 300
# Exportar Gráfico 1: LDA Manual
png(filename = paste0("Caso_", num_caso, "_1_LDA_Manual.png"),
width = ancho_pulgadas, height = alto_pulgadas, units = "in", res = resolucion_dpi)
print(g1)
dev.off()
# Exportar Gráfico 2: LDA MASS
png(filename = paste0("Caso_", num_caso, "_2_LDA_MASS.png"),
width = ancho_pulgadas, height = alto_pulgadas, units = "in", res = resolucion_dpi)
print(g2)
dev.off()
message(paste("¡Caso", num_caso, "procesado y gráficos exportados con éxito!"))
}
