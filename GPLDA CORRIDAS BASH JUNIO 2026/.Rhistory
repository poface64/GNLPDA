testKr  <- as.data.frame(predict(k_rbf, as.matrix(testX)))
acc_kgauss <- mean(predict(lda(y ~ ., data = trainKr), testKr)$class == testY)
metricas_ds <- rbind(metricas_ds, data.frame(
Dataset = ds_nombre,
LDA_Puro = acc_lda,
PCA_LDA = acc_pcalda,
KPCA_Poly2 = acc_kpoly2,
KPCA_Poly3 = acc_kpoly3,
KPCA_Gauss = acc_kgauss
))
}
resumen_ds <- metricas_ds %>%
group_by(Dataset) %>%
summarise(across(everything(), list(Mean = mean, SD = sd)))
resumen_global <- rbind(resumen_global, resumen_ds)
}
return(resumen_global)
}
# --- GENERACIÓN DE TABLA FINAL PARA DIAPOSITIVA ---
resultado_final <- ejecutar_comparativa_express(RUTA_DATASETS)
tabla_formateada <- resultado_final %>%
mutate(
`LDA Puro`    = paste0(round(LDA_Puro_Mean, 4), " ± ", round(LDA_Puro_SD, 4)),
`PCA + LDA`   = paste0(round(PCA_LDA_Mean, 4), " ± ", round(PCA_LDA_SD, 4)),
`KPCA Poly 2` = paste0(round(KPCA_Poly2_Mean, 4), " ± ", round(KPCA_Poly2_SD, 4)),
`KPCA Poly 3` = paste0(round(KPCA_Poly3_Mean, 4), " ± ", round(KPCA_Poly3_SD, 4)),
`KPCA Gauss`  = paste0(round(KPCA_Gauss_Mean, 4), " ± ", round(KPCA_Gauss_SD, 4))
) %>%
select(Dataset, `LDA Puro`, `PCA + LDA`, `KPCA Poly 2`, `KPCA Poly 3`, `KPCA Gauss`)
tb(tabla_formateada)
