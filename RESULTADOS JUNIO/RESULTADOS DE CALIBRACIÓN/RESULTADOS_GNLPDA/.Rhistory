# 1. Cargar las librerías necesarias
library(dplyr)
library(readr) # O library(readxl) si los archivos son .xlsx
library(purrr)
# 2. Definir la ruta del directorio
ruta_directorio <- "C:/Users/Angeal/Desktop/GNLPDA/RESULTADOS JUNIO/RESULTADOS DE CALIBRACIÓN/RESULTADOS_GNLPDA"
# 3. Listar todos los archivos del directorio (asumiendo formato .csv)
# Si son archivos de Excel, cambiar ".csv" por ".xlsx" o ".xls"
archivos <- list.files(path = ruta_directorio, pattern = "\\.csv$", full.names = TRUE)
# 4. Función para leer y preprocesar cada archivo individual
procesar_archivo <- function(ruta) {
# Leer el archivo
df <- read_csv(ruta) # Cambiar a read_excel(ruta) si aplica
# Se asume que hay una columna 'Dataset' o se extrae del nombre del archivo
# En este caso, se añade el nombre del archivo como identificador del dataset
df <- df %>%
mutate(Dataset = basename(ruta)) %>%
mutate(Corrida = row_number()) # Crear un identificador de corrida si no existe
return(df)
}
# 5. Cargar todos los datos en un solo DataFrame y aplicar filtros
datos_completos <- archivos %>%
map_df(~ procesar_archivo(.x)) %>%
# Filtrar y eliminar las corridas 11, 32 y 33
filter(!Corrida %in% c(11, 32, 33))
# 6. Generar la tabla de resumen requerida
tabla_resumen <- datos_completos %>%
group_by(Dataset) %>%
summarise(
# Métricas para Accuracy
Acc_Min    = min(Accuracy, na.rm = TRUE),
Acc_Max    = max(Accuracy, na.rm = TRUE),
Acc_Median = median(Accuracy, na.rm = TRUE),
Acc_Mean   = mean(Accuracy, na.rm = TRUE),
Acc_Std    = sd(Accuracy, na.rm = TRUE),
# Métricas para el Tiempo en Segundos
Tiempo_Promedio = mean(Tiempo_Julia_AG, na.rm = TRUE),
Tiempo_Std      = sd(Tiempo_Julia_AG, na.rm = TRUE)
)
# 5. Cargar todos los datos en un solo DataFrame y aplicar filtros
datos_completos <- archivos %>%
map_df(~ procesar_archivo(.x)) %>%
# Filtrar y eliminar las corridas 11, 32 y 33
filter(!Corrida %in% c(11, 32, 33))
datos_completos
# 1. Cargar las librerías necesarias
library(dplyr)
library(readr) # O library(readxl) si los archivos son .xlsx
library(purrr)
# 2. Definir la ruta del directorio
ruta_directorio <- "C:/Users/Angeal/Desktop/GNLPDA/RESULTADOS JUNIO/RESULTADOS DE CALIBRACIÓN/RESULTADOS_GNLPDA"
# 3. Listar todos los archivos del directorio (asumiendo formato .csv)
# Si son archivos de Excel, cambiar ".csv" por ".xlsx" o ".xls"
archivos <- list.files(path = ruta_directorio, pattern = "\\.csv$", full.names = TRUE)
archivos
# 4. Función para leer y preprocesar cada archivo individual
procesar_archivo <- function(ruta) {
# Leer el archivo
df <- read_csv(ruta) # Cambiar a read_excel(ruta) si aplica
# Se asume que hay una columna 'Dataset' o se extrae del nombre del archivo
# En este caso, se añade el nombre del archivo como identificador del dataset
df <- df %>%
mutate(Dataset = basename(ruta)) %>%
mutate(Corrida = row_number()) # Crear un identificador de corrida si no existe
return(df)
}
# 5. Cargar todos los datos en un solo DataFrame y aplicar filtros
datos_completos <- archivos %>%
map_df(~ procesar_archivo(.x)) %>%
# Filtrar y eliminar las corridas 11, 32 y 33
filter(!Corrida %in% c(11, 32, 33))
# 6. Generar la tabla de resumen requerida
tabla_resumen <- datos_completos %>%
group_by(Dataset) %>%
summarise(
# Métricas para Accuracy
Acc_Min    = min(Accuracy, na.rm = TRUE),
Acc_Max    = max(Accuracy, na.rm = TRUE),
Acc_Median = median(Accuracy, na.rm = TRUE),
Acc_Mean   = mean(Accuracy, na.rm = TRUE),
Acc_Std    = sd(Accuracy, na.rm = TRUE),
# Métricas para el Tiempo en Segundos
Tiempo_Promedio = mean(Tiempo_Julia_AG, na.rm = TRUE),
Tiempo_Std      = sd(Tiempo_Julia_AG, na.rm = TRUE)
)
# 7. Visualizar y exportar el resultado
print(tabla_resumen)
# Opcional: Guardar el resumen en un nuevo archivo CSV
write_csv(tabla_resumen, file.path(ruta_directorio, "Resumen_GNLPDA.csv"))
tabla_resumen[,-1] = tabla_resumen[,-1] |> round(digits = 2)
