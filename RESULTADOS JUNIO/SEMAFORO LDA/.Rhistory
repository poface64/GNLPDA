#### Gráficador KFDA ####
graficadorKFDA <- function(num_caso, dataset_original, tabla_meta) {
# Extraer metadatos específicos del caso
meta <- tabla_meta[tabla_meta$Caso == num_caso, ]
# Extraer la variable objetivo para la asignación de colores (asumiendo que es la última columna)
y <- dataset_original[, ncol(dataset_original)]
clases <- as.factor(y)
# Subtítulo adaptado para KFDA (Variables originales y Kernel)
sub_titulo <- paste0("Obs: ", meta$Obs, " | Vars Orig: ", meta$Vars, " | Kernel: Gaussiano")
# -------------------------------------------------------------------------
# METODO: KFDA (Con datos originales)
# -------------------------------------------------------------------------
# Se ejecuta kfda directamente sobre la matriz original sin expandir
mk1 <- kfda(dataset_original, kernel.name = "rbfdot")
# Extraer las primeras 2 dimensiones de la proyección (Garantizado para 3 clases)
df_kfda <- data.frame(Re(mk1$LDs[, 1:2]))
colnames(df_kfda) <- c("LD1", "LD2")
df_kfda$Class <- clases
# Construcción del gráfico con ggplot2
g3 <- ggplot(df_kfda, aes(x = LD1, y = LD2, color = Class)) +
geom_point(pch = 16, size = 3, alpha = 0.8) +
labs(title = paste0("KFDA ", num_caso), subtitle = sub_titulo, x = "LD1", y = "LD2")
# -------------------------------------------------------------------------
# APLICAR ESTILO COHESIVO IDÉNTICO
# -------------------------------------------------------------------------
estilo_comun <- theme_minimal() +
theme(
plot.title = element_text(face = "bold", size = 14, hjust = 0.5),
plot.subtitle = element_text(size = 11, color = "gray30", hjust = 0.5),
axis.title = element_text(size = 11, face = "bold"),
legend.position = "bottom",
legend.title = element_blank(),
legend.text = element_text(size = 10)
)
g3 <- g3 + estilo_comun
# -------------------------------------------------------------------------
# CONFIGURACIÓN DE EXPORTACIÓN (Dimensiones idénticas para la diapositiva)
# -------------------------------------------------------------------------
ancho_pulgadas <- 5
alto_pulgadas <- 4.5
resolucion_dpi <- 300
# Exportar Gráfico 3: KFDA
png(filename = paste0("Caso_", num_caso, "_3_KFDA.png"),
width = ancho_pulgadas, height = alto_pulgadas, units = "in", res = resolucion_dpi)
print(g3)
dev.off()
message(paste("¡KFDA Caso", num_caso, "procesado y gráfico exportado con éxito!"))
}
