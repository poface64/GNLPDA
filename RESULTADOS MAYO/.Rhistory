# Directorios específicos de logs para las 30 corridas
ruta_logs_mass        <- file.path(ruta_base, "RESULTADOS DE CALIBRACIÓN\\RESULTADOS_LDA")
ruta_logs_kfda        <- file.path(ruta_base, "RESULTADOS DE CALIBRACIÓN\\RESULTADOS_KFDA")
ruta_logs_gnlpda      <- file.path(ruta_base, "RESULTADOS DE CALIBRACIÓN\\RESULTADOS DETALLE GNLPDA 33 CORRIDAS")
# NUEVAS CARPETAS DE EXPORTACIÓN EXCLUSIVAS PARA PROYECCIONES REALES
ruta_salida_tripticos <- file.path(ruta_base, "RESULTADOS DE CALIBRACIÓN\\Gráficos proyecciones triptico")
