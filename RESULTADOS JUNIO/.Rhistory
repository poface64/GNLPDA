idx_val_interno <- pliegues_internos[[f]]
X_t_interno <- X_train_run[-idx_val_interno, , drop = FALSE]
y_t_interno <- y_train_run[-idx_val_interno]
X_v_interno <- X_train_run[idx_val_interno, , drop = FALSE]
y_v_interno <- y_train_run[idx_val_interno]
tryCatch({
# kernel = "polynomial", degree = 2, coef0 = 1 (No homogéneo)
modelo_interno  <- e1071::svm(x = X_t_interno, y = y_t_interno,
kernel = "polynomial", degree = 2, coef0 = 1,
cost = c_cand, gamma = gamma_cand)
preds_v_interno <- predict(modelo_interno, X_v_interno)
acc_pliegues[f] <- sum(preds_v_interno == y_v_interno) / length(y_v_interno)
}, error = function(e) { acc_pliegues[f] <- 0 })
}
acc_malla[comb] <- mean(acc_pliegues)
}
# Seleccionar la mejor combinación de hiperparámetros
mejor_comb   <- which.max(acc_malla)
c_optimo     <- malla_tuning$C[mejor_comb]
gamma_optimo <- malla_tuning$Gamma[mejor_comb]
# EVALUACIÓN EXTERNA DEFINITIVA SOBRE EL 30% TEST OCULTO
modelo_final         <- e1071::svm(x = X_train_run, y = y_train_run,
kernel = "polynomial", degree = 2, coef0 = 1,
cost = c_optimo, gamma = gamma_optimo)
predicciones_finales <- predict(modelo_final, X_test_run)
cm <- caret::confusionMatrix(predicciones_finales, y_test_run)
# -> DETENCIÓN DEL CRONÓMETRO Y CÓMPUTO DEL TIEMPO TRANSCURRIDO
tiempo_total    <- proc.time() - tiempo_inicio
tiempo_segundos <- as.numeric(tiempo_total["elapsed"])
if(length(unique(y_train_run)) == 2) {
resultado <- data.frame(
Corrida         = run,
Cost_Optimo     = c_optimo,
Gamma_Optimo    = gamma_optimo,
Accuracy        = cm$overall["Accuracy"],
Kappa           = cm$overall["Kappa"],
Macro_F1        = cm$byClass["F1"],
Macro_Rec       = cm$byClass["Sensitivity"],
Macro_Prec      = cm$byClass["Precision"],
Tiempo_Segundos = tiempo_segundos,
stringsAsFactors = FALSE)
} else {
resultado = data.frame(
Corrida         = run,
Cost_Optimo     = c_optimo,
Gamma_Optimo    = gamma_optimo,
Accuracy        = cm$overall["Accuracy"],
Kappa           = cm$overall["Kappa"],
Macro_F1        = mean(cm$byClass[, "F1"], na.rm = TRUE),
Macro_Rec       = mean(cm$byClass[, "Sensitivity"], na.rm = TRUE),
Macro_Prec      = mean(cm$byClass[, "Precision"], na.rm = TRUE),
Tiempo_Segundos = tiempo_segundos,
stringsAsFactors = FALSE
)
}
resultado
}, future.seed = TRUE)
# 3. Consolidar la lista devuelta por future_lapply en un solo DataFrame
df_res_instancia <- do.call(rbind, resultados_lista)
write.csv(df_res_instancia,
file = file.path(ruta_resultados, paste0(nombre_base, "_res_svm_poly2.csv")),
row.names = FALSE)
cat("Resultados consolidados guardados con éxito para:", nombre_base, "\n")
}
# 4. Cerrar el plan paralelo volviendo al flujo secuencial
plan(sequential)
cat("\n==================================================================\n")
cat("Proceso completado. Clúster de 'future' liberado.\n")
cat("==================================================================\n")
