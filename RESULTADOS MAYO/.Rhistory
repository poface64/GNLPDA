# Creación automática de los directorios en disco si no existen
if (!dir.exists(ruta_salida_tripticos)) dir.create(ruta_salida_tripticos, recursive =T)
if (!dir.exists(ruta_salida_indiv))     dir.create(ruta_salida_indiv,recursive = T)
