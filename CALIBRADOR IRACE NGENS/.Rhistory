plot(df$V1, df$V2, col = df$class, pch = 20, main = "Dataset Cebolla (Onion)")
df <- cebollaND(n_samples = 600, n_dims = 2, n_classes = 3, noise = 0.1)
plot(df$V1, df$V2, col = df$class, pch = 20, main = "Dataset Cebolla (Onion)")
